# =========================
# CodeSeek Backend Env
# =========================

# App/Auth
CODESEEK_API_KEY=change-me
CODESEEK_APP_ENCRYPTION_KEY=change-me-32-byte-or-generated-key
CODESEEK_REQUIRE_EXPLICIT_APP_ENCRYPTION_KEY=1
CODESEEK_TENANT_ID=local

# CORS / URLs
CODESEEK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CODESEEK_FRONTEND_URL=http://localhost:5173

# Security
CODESEEK_AUTH_SESSION_SECURE_COOKIE=0
CODESEEK_ENFORCE_HTTPS=0
CODESEEK_TRUST_X_FORWARDED_PROTO=1
CODESEEK_ALLOW_PLAINTEXT_SECRET_SUBMISSION=0

# Database - local default
CODESEEK_DB_BACKEND=sqlite
CODESEEK_SQLITE_PATH=../data/codeseek.db

# Database - production example
# CODESEEK_DB_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@host:5432/codeseek
# CODESEEK_DATABASE_URL=postgresql://user:password@host:5432/codeseek

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Retrieval workspace
RETRIEVAL_REPO_ROOT=/tmp/codeseek_repo_workspace

# LLM
RETRIEVAL_LOCAL_LLM_PRIMARY_MODEL=qwen2.5-coder:3b-5k
CODESEEK_DESCRIPTION_MODEL=qwen2.5-coder:3b
CODESEEK_LABEL_MODEL=qwen2.5-coder:3b

# Generation settings
CODESEEK_DESCRIPTION_NUM_CTX=4096
CODESEEK_LABEL_NUM_CTX=2048
CODESEEK_DESCRIPTION_MAX_TOKENS=160
CODESEEK_LABEL_MAX_TOKENS=128
CODESEEK_DESCRIPTION_BATCH_SIZE=1
CODESEEK_LABEL_REFINE_BATCH_SIZE=4
CODESEEK_EMBEDDING_BATCH_SIZE=16
CODESEEK_CHUNK_PROCESS_BATCH_SIZE=32
CODESEEK_DESCRIPTION_MAX_CHARS=600
CODESEEK_OLLAMA_KEEP_ALIVE=30s

# Cooldown settings
CODESEEK_DESCRIPTION_COOLDOWN_EVERY=200
CODESEEK_DESCRIPTION_COOLDOWN_SECONDS=60
CODESEEK_EMBEDDING_COOLDOWN_EVERY=200
CODESEEK_EMBEDDING_COOLDOWN_SECONDS=80

# Features
CODESEEK_ENABLE_INCREMENTAL_REINDEX=true
