# Render
# Render injects PORT automatically; do not set it manually unless running locally.
PORT=

# CORS
# Set CORS_ALLOWED_ORIGINS to your Vercel frontend URL in production.
CORS_ALLOWED_ORIGINS=

CODESEEK_API_KEY=replace-with-random-api-key
CODESEEK_APP_ENCRYPTION_KEY=replace-with-32-plus-random-chars
CODESEEK_REQUIRE_EXPLICIT_APP_ENCRYPTION_KEY=1
CODESEEK_DB_BACKEND=sqlite
CODESEEK_SQLITE_PATH=../data/codeseek.db

# CODESEEK_DB_BACKEND=postgres
# Metadata DB - Neon/Postgres
# Use the actual env name supported by CodeSeek:
# CODESEEK_DATABASE_URL=postgresql://codeseek:codeseek@localhost:5432/codeseek

# Vector Database (Qdrant)
# By default, CodeSeek connects to a local Qdrant instance at localhost:6333.
QDRANT_HOST=localhost
QDRANT_PORT=6333
# For production, provide the Qdrant Cloud URL and API key (takes precedence):
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=10.0


CODESEEK_AUTH_SESSION_SECURE_COOKIE=1
CODESEEK_ENFORCE_HTTPS=1
CODESEEK_TRUST_X_FORWARDED_PROTO=1
CODESEEK_ALLOW_PLAINTEXT_SECRET_SUBMISSION=0
CODESEEK_CORS_ORIGINS=https://your-frontend.example.com
CODESEEK_TENANT_ID=prod
RETRIEVAL_REPO_ROOT=/tmp/codeseek_repo_workspace
RETRIEVAL_LOCAL_LLM_BASE_URL=http://localhost:11434/v1
RETRIEVAL_LOCAL_LLM_TIMEOUT_SECONDS=20.0
RETRIEVAL_LOCAL_LLM_PRIMARY_MODEL=qwen2.5-coder:3b-8k
RETRIEVAL_LOCAL_LLM_COMPLEX_MODEL=qwen-coder-7b-8192
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-backend.example.com/auth/github/callback
CODESEEK_FRONTEND_URL=https://your-frontend.example.com

# --- Ingestion Stability / Resource Management Settings ---
# Models to use for background ingestion enrichment (descriptions and label refinement)
CODESEEK_DESCRIPTION_MODEL=qwen2.5-coder:3b
CODESEEK_LABEL_MODEL=qwen2.5-coder:3b

# Batch size controls - smaller values reduce RAM/GPU VRAM pressure
CODESEEK_DESCRIPTION_BATCH_SIZE=1
CODESEEK_LABEL_REFINE_BATCH_SIZE=4
CODESEEK_EMBEDDING_BATCH_SIZE=16
CODESEEK_CHUNK_PROCESS_BATCH_SIZE=32
CODESEEK_EMBEDDING_TIMEOUT_SECONDS=60

# Embeddings default to the existing local SentenceTransformer path.
# Note: Embedding settings can now be overridden per-user via the CodeSeek Frontend UI.
# Changing embedding provider/dimensions (either via env or UI) requires reindexing existing sessions.
CODESEEK_EMBEDDING_PROVIDER=local

# Optional OpenAI-compatible cloud embeddings fallback:
# CODESEEK_EMBEDDING_PROVIDER=openai_compatible
# CODESEEK_EMBEDDING_BASE_URL=https://api.aicredits.in/v1
# CODESEEK_EMBEDDING_API_KEY=replace-with-embedding-api-key
# CODESEEK_EMBEDDING_MODEL=openai/text-embedding-3-small
# CODESEEK_EMBEDDING_DIMENSIONS=
# Note: Supported AICredits embedding models include: openai/text-embedding-3-small (recommended), text-embedding-3-small, openai/text-embedding-3-large, text-embedding-3-large, openai/text-embedding-ada-002, text-embedding-ada-002.
# Note: Google embedding models are listed in AICredits, but keep dimensions on Auto unless verified. If a provider-prefixed model fails, try the plain OpenAI ID (e.g. text-embedding-3-small). Do not use DeepSeek/chat models for embeddings.
# Note: Auto/infer dimensions is recommended (leave blank). CodeSeek will enforce exact size locally if set.

# Max size of LLM generated chunk descriptions (0 to disable character truncation)
CODESEEK_DESCRIPTION_MAX_CHARS=600
CODESEEK_DESCRIPTION_MAX_TOKENS=160
CODESEEK_DESCRIPTION_NUM_CTX=4096
CODESEEK_LABEL_NUM_CTX=2048
CODESEEK_LABEL_MAX_TOKENS=128

# Keep-alive parameter sent to local Ollama API
CODESEEK_OLLAMA_KEEP_ALIVE=30s

# Optional: Evict model from Ollama (via 'ollama stop' / keep_alive=0) every N batches
# Set to 0 to disable, or e.g., 10 to clear model resources regularly
CODESEEK_OLLAMA_STOP_MODEL_EVERY=0

# Cooldown settings for thermal management during description generation
CODESEEK_DESCRIPTION_COOLDOWN_EVERY=150
CODESEEK_DESCRIPTION_COOLDOWN_SECONDS=60

# Cooldown during local embedding generation
CODESEEK_EMBEDDING_COOLDOWN_EVERY=300
CODESEEK_EMBEDDING_COOLDOWN_SECONDS=30

# Enable experimental incremental file indexing (default: false)
CODESEEK_ENABLE_INCREMENTAL_REINDEX=true
